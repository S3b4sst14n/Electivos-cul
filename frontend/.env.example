# URL completa del backend desplegado.
# Dev: déjalo en blanco para usar el proxy de Vite (que apunta a localhost:3000).
# Prod (Vercel): configúralo en el dashboard como https://<tu-app>.up.railway.app/api
VITE_API_URL=

# Solo en desarrollo: target del proxy de Vite si tu backend local no corre en localhost:3000
VITE_DEV_PROXY_TARGET=http://localhost:3000
